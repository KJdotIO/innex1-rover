{
  "name": "INX One Review",
  "url": "https://github.com/KJdotIO/innex1-rover",
  "redirect_url": "https://github.com/KJdotIO/innex1-rover",
  "hook_attributes": {
    "url": "https://github.com/KJdotIO/innex1-rover",
    "active": false
  },
  "public": false,
  "default_permissions": {
    "contents": "read",
    "issues": "write",
    "pull_requests": "write"
  },
  "default_events": [
    "issue_comment",
    "pull_request"
  ]
}
